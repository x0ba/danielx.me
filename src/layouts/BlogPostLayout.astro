---
import BaseLayout from "./BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { absoluteUrl, siteConfig } from "../lib/site";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  cover?: ImageMetadata;
  coverAlt?: string;
  tags?: string[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  cover,
  coverAlt,
  tags = [],
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const canonicalURL = Astro.url;
const ogImage = cover?.src ?? siteConfig.defaultOgImagePath;
const articleStructuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  url: canonicalURL.toString(),
  mainEntityOfPage: canonicalURL.toString(),
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    "@type": "Person",
    name: siteConfig.author.name,
    url: siteConfig.siteUrl,
  },
  publisher: {
    "@type": "Person",
    name: siteConfig.author.name,
    url: siteConfig.siteUrl,
  },
  image: absoluteUrl(ogImage),
  keywords: tags,
  inLanguage: "en-US",
};
---

<BaseLayout
  title={`${title} | Daniel Xu`}
  description={description}
  ogImage={ogImage}
  ogImageAlt={coverAlt || title}
  pageType="article"
  keywords={tags}
  publishedTime={pubDate}
  modifiedTime={updatedDate ?? pubDate}
  structuredData={articleStructuredData}
>
  <div class="top-bar" aria-hidden="true"></div>

  <!-- Full-viewport article hero, matching homepage hero -->
  <section class="article-hero">
    <PageHeader currentPath="/blog" />

    <div class="hero-center">
      <a
        href="/blog"
        class="post-back"
        style="animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.05s both"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M19 12H5"></path><path d="M12 19l-7-7 7-7"></path></svg
        >
        all posts
      </a>

      <h1
        class="article-title"
        style="animation: fadeSlideUp 0.8s cubic-bezier(0.16,1,0.3,1) 0.1s both"
      >
        {title}
      </h1>

      <p
        class="article-desc"
        style="animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.15s both"
      >
        {description}
      </p>

      <div
        class="article-meta"
        style="animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.2s both"
      >
        <time datetime={pubDate.toISOString()}>
          {formattedDate}
        </time>
        {
          updatedDate && (
            <>
              <span class="meta-sep">·</span>
              <span class="meta-updated">updated {formattedUpdatedDate}</span>
            </>
          )
        }
      </div>

      {
        tags.length > 0 && (
          <div
            class="article-tags"
            style="animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.25s both"
          >
            {tags.map((tag) => (
              <span class="article-tag">{tag}</span>
            ))}
          </div>
        )
      }
    </div>

    <div class="scroll-hint" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M12 5v14"></path><path d="m19 12-7 7-7-7"></path></svg
      >
    </div>
  </section>

  <!-- Content -->
  <div class="content">
    {
      cover && (
        <div
          class="article-cover"
          style="animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.28s both"
        >
          <img
            src={cover.src}
            alt={coverAlt || title}
            width={cover.width}
            height={cover.height}
          />
        </div>
      )
    }

    <!-- Article Body -->
    <section id="article" class="sec">
      <article
        class="prose"
        style="animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.3s both"
      >
        <slot />
      </article>
    </section>

    <!-- Footer -->
    <footer
      class="foot"
      style="animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.35s both"
    >
      <a href="/blog" class="post-back">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M19 12H5"></path><path d="M12 19l-7-7 7-7"></path></svg
        >
        back to all posts
      </a>
      <p class="foot-copy">© 2026 Daniel Xu</p>
    </footer>
  </div>
</BaseLayout>

<style>
  /* ── Top Bar ───────────────────── */
  .top-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(
      180deg,
      var(--color-accent-hover),
      var(--color-accent),
      #c03000
    );
    z-index: 100;
    box-shadow:
      0 1px 4px rgba(255, 61, 0, 0.3),
      0 0 12px rgba(255, 61, 0, 0.15);
  }

  /* ── Hero (matching homepage hero structure) ─── */
  .article-hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    padding: clamp(1.5rem, 3vw, 3rem) clamp(1rem, 4vw, 3rem) 2rem;
    position: relative;
    overflow: hidden;
  }



  .hero-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 2rem 0;
    max-width: 1000px;
  }

  .post-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: color 0.2s;
    margin-bottom: 1.5rem;
  }
  .post-back:hover {
    color: var(--color-accent);
  }
  .post-back:hover svg {
    transform: translateX(-3px);
  }
  .post-back svg {
    transition: transform 0.2s;
  }

  .article-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(3rem, 8vw, 6rem);
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin: 0;
    color: var(--color-primary);
    text-shadow:
      0 1px 0 rgba(255, 255, 255, 0.03),
      0 -1px 0 rgba(0, 0, 0, 0.4);
  }

  .article-desc {
    font-size: 1.05rem;
    color: var(--color-secondary);
    line-height: 1.65;
    margin-top: 1.5rem;
    max-width: 650px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
    font-size: 0.75rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .meta-sep {
    color: var(--color-edge-hover);
  }
  .meta-updated {
    font-style: italic;
    text-transform: none;
    letter-spacing: 0;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .article-tag {
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    padding: 0.2rem 0.65rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    background: var(--color-accent-dim);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 1px 2px rgba(0, 0, 0, 0.15);
    position: relative;
  }
  .article-tag::before,
  .article-tag::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-accent) 30%, transparent);
    transform: translateY(-50%);
  }
  .article-tag::before {
    left: -6px;
  }
  .article-tag::after {
    right: -6px;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-muted);
    opacity: 0.4;
    animation: bobDown 2s ease-in-out infinite;
  }
  @keyframes bobDown {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(6px);
    }
  }

  /* ── Content ───────────────────── */
  .content {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem);
  }

  /* ── Article Cover ─────────────── */
  .article-cover {
    margin: 0 0 -1rem;
    border: 1px solid var(--color-edge);
    overflow: hidden;
    border-radius: 4px;
  }
  .article-cover img {
    display: block;
    width: 100%;
  }

  /* ── Sections ──────────────────── */
  .sec {
    padding: 4rem 0 4rem;
    border-top: 1px solid var(--color-edge);
  }

  /* ── Footer ────────────────────── */
  .foot {
    border-top: 1px solid var(--color-edge);
    padding: 2.5rem 0 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .foot-copy {
    font-size: 0.65rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
  }

  /* ── Mobile ────────────────────── */
  @media (max-width: 768px) {
    .article-hero {
      min-height: 640px;
      min-height: 100svh;
    }
    .hero-center {
      justify-content: center;
      padding: 2.5rem 0 1.5rem;
    }
    .article-title {
      font-size: clamp(2.3rem, 13vw, 4rem);
      line-height: 1;
      overflow-wrap: anywhere;
    }
    .article-desc {
      font-size: 1rem;
      line-height: 1.6;
    }
    .sec {
      padding: 3rem 0 2.5rem;
    }
    .scroll-hint {
      display: none;
    }
  }

  @media (max-width: 430px) {
    .article-meta {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.35rem;
    }
    .meta-sep {
      display: none;
    }
  }

</style>
