---
import BaseLayout from "./BaseLayout.astro";
import { absoluteUrl, siteConfig } from "../lib/site";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  cover?: ImageMetadata;
  coverAlt?: string;
  tags?: string[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  cover,
  coverAlt,
  tags = [],
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const canonicalURL = Astro.url;
const ogImage = cover?.src ?? siteConfig.defaultOgImagePath;
const articleStructuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  url: canonicalURL.toString(),
  mainEntityOfPage: canonicalURL.toString(),
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    "@type": "Person",
    name: siteConfig.author.name,
    url: siteConfig.siteUrl,
  },
  publisher: {
    "@type": "Person",
    name: siteConfig.author.name,
    url: siteConfig.siteUrl,
  },
  image: absoluteUrl(ogImage),
  keywords: tags,
  inLanguage: "en-US",
};
---

<BaseLayout
  title={`${title} | Daniel Xu`}
  description={description}
  ogImage={ogImage}
  ogImageAlt={coverAlt || title}
  pageType="article"
  keywords={tags}
  publishedTime={pubDate}
  modifiedTime={updatedDate ?? pubDate}
  structuredData={articleStructuredData}
>
  <div class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute left-1/2 top-0 h-[600px] w-[900px] -translate-x-1/2"
      style="background: radial-gradient(ellipse at 50% 0%, rgba(198, 122, 74, 0.045), transparent 70%);"
    >
    </div>

    <div class="relative mx-auto max-w-2xl px-6">
      <!-- Nav -->
      <nav
        class="flex items-center justify-between py-8 opacity-0 animate-reveal"
      >
        <a
          href="/"
          class="text-sm font-medium tracking-tight transition-colors hover:text-accent"
        >
          daniel xu
        </a>
        <div class="flex gap-5 text-sm">
          <a
            href="/"
            class="link-hover text-muted transition-colors hover:text-primary"
          >
            home
          </a>
          <a href="/blog" class="link-hover text-primary transition-colors">
            blog
          </a>
        </div>
      </nav>

      <!-- Article Header -->
      <header class="pb-10 pt-12 sm:pt-16">
        <a
          href="/blog"
          class="group inline-flex items-center gap-1.5 text-sm text-muted transition-colors hover:text-accent opacity-0 animate-reveal"
          style="animation-delay: 0.04s"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-transform group-hover:-translate-x-0.5"
          >
            <path d="M19 12H5"></path>
            <path d="M12 19l-7-7 7-7"></path>
          </svg>
          all posts
        </a>

        <h1
          class="mt-6 text-3xl font-bold tracking-tight opacity-0 animate-reveal sm:text-4xl"
          style="animation-delay: 0.08s"
        >
          {title}
        </h1>

        <p
          class="mt-3 text-base text-secondary leading-relaxed opacity-0 animate-reveal"
          style="animation-delay: 0.12s"
        >
          {description}
        </p>

        <div
          class="mt-5 flex flex-wrap items-center gap-3 text-sm opacity-0 animate-reveal"
          style="animation-delay: 0.16s"
        >
          <time datetime={pubDate.toISOString()} class="text-muted">
            {formattedDate}
          </time>
          {
            updatedDate && (
              <>
                <span class="text-edge-hover">·</span>
                <span class="text-muted italic">
                  updated {formattedUpdatedDate}
                </span>
              </>
            )
          }
        </div>

        {
          tags.length > 0 && (
            <div
              class="mt-4 flex flex-wrap gap-1.5 opacity-0 animate-reveal"
              style="animation-delay: 0.2s"
            >
              {tags.map((tag) => (
                <span class="rounded-full bg-accent-dim px-2.5 py-0.5 text-xs text-accent">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </header>

      {
        cover && (
          <div
            class="mb-12 overflow-hidden rounded-xl border border-edge opacity-0 animate-reveal"
            style="animation-delay: 0.24s"
          >
            <img
              src={cover.src}
              alt={coverAlt || title}
              width={cover.width}
              height={cover.height}
              class="w-full"
            />
          </div>
        )
      }

      <!-- Article Body -->
      <article
        class="prose opacity-0 animate-reveal"
        style="animation-delay: 0.28s"
      >
        <slot />
      </article>

      <!-- Footer -->
      <footer
        class="border-t border-edge pb-12 pt-8 mt-16 opacity-0 animate-reveal"
        style="animation-delay: 0.32s"
      >
        <a
          href="/blog"
          class="group inline-flex items-center gap-1.5 text-sm text-muted transition-colors hover:text-accent"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-transform group-hover:-translate-x-0.5"
          >
            <path d="M19 12H5"></path>
            <path d="M12 19l-7-7 7-7"></path>
          </svg>
          back to all posts
        </a>
        <p class="mt-8 text-xs text-muted">
          © 2026 Daniel Xu. built with ❤️ in la jolla, ca
        </p>
      </footer>
    </div>
  </div>
</BaseLayout>
