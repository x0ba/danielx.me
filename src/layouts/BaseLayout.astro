---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { siteConfig } from "../lib/site";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogImageAlt?: string;
  pageType?: "website" | "article";
  noindex?: boolean;
  keywords?: string[];
  publishedTime?: Date;
  modifiedTime?: Date;
  canonicalPath?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  ogImage,
  ogImageAlt,
  pageType = "website",
  noindex = false,
  keywords = [],
  publishedTime,
  modifiedTime,
  canonicalPath,
  structuredData,
} = Astro.props;

const site = Astro.site ?? new URL(siteConfig.siteUrl);
const canonicalURL = canonicalPath ? new URL(canonicalPath, site) : Astro.url;
const ogImageURL = new URL(ogImage ?? siteConfig.defaultOgImagePath, site);
const canonicalHref = canonicalURL.toString();
const ogImageHref = ogImageURL.toString();
const robotsContent = noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large";
const keywordsContent = keywords.length > 0 ? keywords.join(", ") : undefined;
const structuredDataEntries = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content={robotsContent} />
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.author.name} />
    {keywordsContent && <meta name="keywords" content={keywordsContent} />}
    <meta name="theme-color" content="#0b0d12" data-theme-color />
    <script is:inline>
      (() => {
        const storageKey = "danielx-theme";
        const themes = { dark: "#0b0d12", light: "#f6efe4" };
        const getStoredTheme = () => {
          try {
            return localStorage.getItem(storageKey) || "system";
          } catch {
            return "system";
          }
        };
        const resolveTheme = (theme) =>
          theme === "system"
            ? window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light"
            : theme;

        const selectedTheme = getStoredTheme();
        const resolvedTheme = resolveTheme(selectedTheme);
        document.documentElement.dataset.theme = selectedTheme;
        document.documentElement.dataset.resolvedTheme = resolvedTheme;
        document.documentElement.style.colorScheme = resolvedTheme;
        document
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute("content", themes[resolvedTheme]);
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:site_name" content={siteConfig.author.name} />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:image" content={ogImageHref} />
    <meta property="og:image:alt" content={ogImageAlt ?? title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageHref} />
    <meta name="twitter:image:alt" content={ogImageAlt ?? title} />
    <meta name="twitter:creator" content={siteConfig.twitterHandle} />
    <meta name="twitter:site" content={siteConfig.twitterHandle} />
    <link rel="sitemap" href={new URL("/sitemap-index.xml", site)} />
    {
      pageType === "article" && publishedTime && (
        <meta
          property="article:published_time"
          content={publishedTime.toISOString()}
        />
      )
    }
    {
      pageType === "article" && modifiedTime && (
        <meta
          property="article:modified_time"
          content={modifiedTime.toISOString()}
        />
      )
    }
    {
      pageType === "article" &&
        keywords.map((keyword) => (
          <meta property="article:tag" content={keyword} />
        ))
    }
    {
      structuredDataEntries.map((entry) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(entry)}
        />
      ))
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen">
    <slot />

    <div
      class="theme-toggle opacity-0 animate-reveal"
      style="animation-delay: 0.9s"
      role="radiogroup"
      aria-label="Color theme"
      data-theme-toggle
    >
      <button type="button" role="radio" data-theme-option="system" aria-label="Use system theme">
        <span aria-hidden="true">◐</span>
      </button>
      <button type="button" role="radio" data-theme-option="light" aria-label="Use light theme">
        <span aria-hidden="true">☼</span>
      </button>
      <button type="button" role="radio" data-theme-option="dark" aria-label="Use dark theme">
        <span aria-hidden="true">☾</span>
      </button>
    </div>

    <script is:inline>
      (() => {
        const storageKey = "danielx-theme";
        const validThemes = ["system", "light", "dark"];
        const themeColors = { dark: "#0b0d12", light: "#f6efe4" };
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        const toggle = document.querySelector("[data-theme-toggle]");
        if (!toggle) return;

        const getTheme = () => {
          try {
            const stored = localStorage.getItem(storageKey);
            return validThemes.includes(stored) ? stored : "system";
          } catch {
            return "system";
          }
        };

        const resolved = (theme) =>
          theme === "system" ? (media.matches ? "dark" : "light") : theme;

        const applyTheme = (theme) => {
          const resolvedTheme = resolved(theme);
          document.documentElement.dataset.theme = theme;
          document.documentElement.dataset.resolvedTheme = resolvedTheme;
          document.documentElement.style.colorScheme = resolvedTheme;
          document
            .querySelector('meta[name="theme-color"]')
            ?.setAttribute("content", themeColors[resolvedTheme]);

          toggle.querySelectorAll("[data-theme-option]").forEach((button) => {
            const isActive = button.getAttribute("data-theme-option") === theme;
            button.setAttribute("aria-checked", String(isActive));
          });
        };

        toggle.addEventListener("click", (event) => {
          const button = event.target.closest("[data-theme-option]");
          if (!button) return;
          const theme = button.getAttribute("data-theme-option");
          if (!validThemes.includes(theme)) return;
          try {
            localStorage.setItem(storageKey, theme);
          } catch {}
          applyTheme(theme);
        });

        media.addEventListener("change", () => {
          if (getTheme() === "system") applyTheme("system");
        });

        applyTheme(getTheme());
      })();
    </script>
  </body>
</html>
