---
import { Image } from "astro:assets";
import fieldPhoto from "../assets/photos/field.jpg";
import housePhoto from "../assets/photos/house.jpg";
import skyPhoto from "../assets/photos/sky.jpg";
import sungodPhoto from "../assets/photos/sungod.jpg";
import vicesAndVirtuesPhoto from "../assets/photos/vices_and_virtues.jpg";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";

import { siteConfig } from "../lib/site";

const pageTitle = "Photos — Daniel Xu";
const pageDescription =
  "A curated collection of photographs by Daniel Xu. Street, landscape, and architectural photography shot on film and digital.";

const photos = [
  {
    src: housePhoto,
    title: "house on house",
    location: "la jolla, ca",
    camera: "iphone 17 pro",
    year: "2026",
    category: "street",
    width: 5780,
    height: 7470,
  },
  {
    src: sungodPhoto,
    title: "sun god",
    location: "la jolla, ca",
    camera: "iphone 17 pro",
    year: "2026",
    category: "architecture",
    width: 3024,
    height: 4032,
  },
  {
    src: fieldPhoto,
    title: "field notes",
    location: "california",
    camera: "iphone 17 pro",
    year: "2026",
    category: "landscape",
    width: 4014,
    height: 3011,
  },
  {
    src: skyPhoto,
    title: "sky study",
    location: "california",
    camera: "iphone 17 pro",
    year: "2026",
    category: "landscape",
    width: 8064,
    height: 6048,
  },
  {
    src: vicesAndVirtuesPhoto,
    title: "vices and virtues",
    location: "la jolla, ca",
    camera: "iphone 17 pro",
    year: "2026",
    category: "street",
    width: 4032,
    height: 3024,
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={siteConfig.defaultOgImagePath}
  ogImageAlt="Daniel Xu photography portfolio"
  keywords={[
    "Daniel Xu",
    "photography",
    "film photography",
    "street photography",
    "landscape",
  ]}
>
  <div class="photos-page">
    <div class="top-bar" aria-hidden="true"></div>

    <!-- Film grain overlay -->
    <div class="grain-overlay" aria-hidden="true"></div>

    <!-- Sprocket holes decoration -->
    <div class="sprocket-strip sprocket-left" aria-hidden="true">
      {Array.from({ length: 30 }).map(() => <div class="sprocket-hole" />)}
    </div>

    <!-- Header -->
    <header class="photos-header">
      <PageHeader currentPath="/photos" usePageColors={true} />
    </header>

    <!-- Page heading -->
    <div class="photos-title-block">
      <h1 class="photos-page-title">Photos</h1>
      <p class="photos-blurb">
        I've been mainly shooting on my iPhone 17 Pro lately. Here are some of
        the photos I've taken. More on
        <a
          href="https://www.instagram.com/shooo.jpeg"
          target="_blank"
          rel="noreferrer"
          class="photos-blurb-link">Instagram</a
        >.
      </p>
    </div>

    <!-- Gallery -->
    <main class="photos-gallery">
      {
        photos.map((photo, i) => (
          <article
            class="photo-frame"
            data-category={photo.category}
            style={`animation-delay: ${0.38 + i * 0.08}s`}
          >
            <div class="frame-inner">
              <div class="frame-image-wrap">
                <Image
                  src={photo.src}
                  alt={photo.title}
                  width={photo.width}
                  height={photo.height}
                  loading={i < 3 ? "eager" : "lazy"}
                  class="frame-image"
                />
                <div class="frame-number" aria-hidden="true">
                  {String(i + 1).padStart(2, "0")}
                </div>
              </div>
              <div class="frame-caption">
                <h2 class="frame-title">{photo.title}</h2>
                <div class="frame-details">
                  <span class="frame-location">{photo.location}</span>
                  <span class="frame-camera">{photo.camera}</span>
                  <span class="frame-year">{photo.year}</span>
                </div>
              </div>
            </div>
            <div class="frame-tape" aria-hidden="true" />
          </article>
        ))
      }
    </main>

    <!-- Footer -->
    <footer class="photos-footer" style="animation-delay: 1.2s">
      <div class="photos-footer-inner">
        <p class="photos-footer-text">shot by daniel xu</p>
        <p class="photos-footer-sub">
          © {new Date().getFullYear()} · all rights reserved
        </p>
      </div>
    </footer>
  </div>
</BaseLayout>

<style>
  /* ── Photography Page — "Darkroom" Aesthetic ──────────────── */

  @import url("https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap");

  .photos-page {
    --photo-bg: #0a0908;
    --photo-surface: #141210;
    --photo-card: #1a1816;
    --photo-border: #2a2623;
    --photo-border-light: #3a3530;
    --photo-cream: #f5f0e8;
    --photo-cream-dim: rgba(245, 240, 232, 0.7);
    --photo-cream-muted: rgba(245, 240, 232, 0.35);
    --photo-amber: #c8956c;
    --photo-amber-bright: #e0a87a;
    --photo-amber-dim: rgba(200, 149, 108, 0.12);
    --photo-amber-glow: rgba(200, 149, 108, 0.06);
    --photo-red: #8b3a3a;
    --photo-tape: rgba(245, 240, 232, 0.06);

    --font-mono: "DM Mono", "Courier New", monospace;

    position: relative;
    min-height: 100vh;
    background: var(--photo-bg);
    color: var(--photo-cream);
    overflow-x: hidden;
  }

  .top-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(
      180deg,
      var(--color-accent-hover),
      var(--color-accent),
      #c03000
    );
    z-index: 110;
    box-shadow:
      0 1px 4px rgba(255, 61, 0, 0.3),
      0 0 12px rgba(255, 61, 0, 0.15);
  }

  /* ── Photos page light mode ──────────────────────────────── */

  :global(html[data-theme="light"]) .photos-page {
    --photo-bg: #f5f0e8;
    --photo-surface: #ebe6dc;
    --photo-card: #e0dbd2;
    --photo-border: #cfc9be;
    --photo-border-light: #bfb9ae;
    --photo-cream: #1a1815;
    --photo-cream-dim: rgba(26, 24, 21, 0.65);
    --photo-cream-muted: rgba(26, 24, 21, 0.35);
    --photo-amber: #8b5e3c;
    --photo-amber-bright: #a0694a;
    --photo-amber-dim: rgba(139, 94, 60, 0.1);
    --photo-amber-glow: rgba(139, 94, 60, 0.05);
    --photo-red: #c04040;
    --photo-tape: rgba(26, 24, 21, 0.05);
  }

  /* ── Grain Overlay ──────────────────────────────────────────── */

  .grain-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    mix-blend-mode: overlay;
  }

  :global(html[data-theme="light"]) .grain-overlay {
    opacity: 0.025;
    mix-blend-mode: multiply;
  }

  /* ── Sprocket Strip ─────────────────────────────────────────── */

  .sprocket-strip {
    position: fixed;
    top: 0;
    bottom: 0;
    width: 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    padding-top: 40px;
    z-index: 10;
    opacity: 0.08;
  }

  :global(html[data-theme="light"]) .sprocket-strip {
    opacity: 0.06;
  }

  :global(html[data-theme="light"]) .sprocket-hole {
    border-color: var(--photo-cream);
  }

  .sprocket-left {
    left: 8px;
  }

  .sprocket-hole {
    width: 10px;
    height: 14px;
    border-radius: 2px;
    border: 1px solid var(--photo-cream);
    flex-shrink: 0;
  }

  /* ── Header ──────────────────────────────────────────────────── */

  .photos-header {
    position: relative;
    z-index: 20;
    padding: clamp(1.5rem, 3vw, 3rem) clamp(1rem, 4vw, 3rem)
      clamp(1.25rem, 3vw, 2rem);
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
    opacity: 0;
    animation: photos-reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* ── Page Title ──────────────────────────────────────────────── */

  .photos-title-block {
    padding: 0 clamp(1rem, 4vw, 3rem);
    max-width: 1400px;
    margin: 0 auto clamp(2rem, 5vw, 3.5rem);
    position: relative;
    z-index: 20;
    opacity: 0;
    animation: photos-reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }

  .photos-page-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 400;
    color: var(--photo-cream);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .photos-blurb {
    max-width: 36rem;
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.6vw, 1.1rem);
    color: var(--photo-cream);
    line-height: 1.6;
    margin: 0.9rem 0 0;
    opacity: 0.78;
  }

  .photos-blurb-link {
    position: relative;
    color: var(--photo-amber-bright);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: var(--photo-amber);
    text-decoration-thickness: 1.5px;
    text-underline-offset: 0.18em;
    transition:
      color 0.2s ease,
      text-decoration-color 0.2s ease;
  }

  .photos-blurb-link::after {
    content: "↗";
    display: inline-block;
    margin-left: 0.18em;
    font-size: 0.78em;
    line-height: 1;
    transform: translateY(-0.08em);
    opacity: 0.85;
  }

  .photos-blurb-link:hover {
    color: var(--photo-cream);
    text-decoration-color: currentColor;
  }

  .photos-blurb-link:focus-visible {
    outline: 2px solid var(--photo-amber);
    outline-offset: 3px;
  }

  /* ── Gallery ────────────────────────────────────────────────── */

  .photos-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    align-items: start;
    gap: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 3vw, 2.5rem);
    padding: 0 clamp(1rem, 3vw, 2.5rem) 6rem clamp(1rem, 4vw, 3rem);
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ── Photo Frame (Polaroid-like) ────────────────────────────── */

  .photo-frame {
    position: relative;
    width: 100%;
    min-width: 0;
    opacity: 0;
    animation: photos-reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    transition:
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.4s ease;
  }

  .photo-frame:nth-child(odd) {
    transform: rotate(-1.2deg);
  }

  .photo-frame:nth-child(even) {
    transform: rotate(0.8deg);
  }

  .photo-frame:nth-child(3n) {
    transform: rotate(-0.5deg) translateY(12px);
  }

  .photo-frame:hover {
    transform: rotate(0deg) translateY(-8px) scale(1.02) !important;
    z-index: 10;
  }

  .frame-inner {
    background: linear-gradient(178deg, #f9f4ec, #ece7df 80%, #e5e0d7);
    padding: 14px 14px 56px 14px;
    box-shadow:
      0 1px 1px rgba(0, 0, 0, 0.15),
      0 3px 8px rgba(0, 0, 0, 0.2),
      0 12px 40px rgba(0, 0, 0, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      inset 0 -1px 0 rgba(0, 0, 0, 0.08);
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.4s ease;
  }

  :global(html[data-theme="light"]) .frame-inner {
    background: linear-gradient(178deg, #faf7f2, #f0ebe3 80%, #e8e3da);
    border-color: rgba(0, 0, 0, 0.05);
    box-shadow:
      0 1px 1px rgba(0, 0, 0, 0.06),
      0 3px 8px rgba(0, 0, 0, 0.06),
      0 12px 40px rgba(0, 0, 0, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      inset 0 -1px 0 rgba(0, 0, 0, 0.04);
  }

  :global(html[data-theme="light"]) .photo-frame:hover .frame-inner {
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.15),
      0 20px 60px rgba(0, 0, 0, 0.1),
      0 0 80px rgba(139, 94, 60, 0.06),
      inset 0 0 0 1px rgba(0, 0, 0, 0.03);
  }

  .photo-frame:hover .frame-inner {
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.4),
      0 20px 60px rgba(0, 0, 0, 0.3),
      0 0 80px var(--photo-amber-dim),
      inset 0 0 0 1px rgba(0, 0, 0, 0.05);
  }

  .frame-image-wrap {
    position: relative;
    overflow: hidden;
    background: #1a1a1a;
  }

  :global(html[data-theme="light"]) .frame-image-wrap {
    background: #e8e4de;
  }

  .frame-image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: contrast(1.05) saturate(0.9);
    transition:
      filter 0.4s ease,
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .photo-frame:hover .frame-image {
    filter: contrast(1.1) saturate(1);
    transform: scale(1.03);
  }

  .frame-number {
    position: absolute;
    bottom: 8px;
    right: 10px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--photo-amber-bright);
    opacity: 0.7;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.8);
    letter-spacing: 0.1em;
  }

  .frame-caption {
    padding-top: 12px;
  }

  .frame-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.1rem;
    color: var(--photo-bg);
    margin: 0;
    letter-spacing: 0.01em;
  }

  :global(html[data-theme="light"]) .frame-title {
    color: #0a0908;
  }

  .frame-details {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    margin-top: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: rgba(10, 9, 8, 0.4);
    letter-spacing: 0.04em;
  }

  :global(html[data-theme="light"]) .frame-details {
    color: rgba(10, 9, 8, 0.5);
  }

  /* Tape decoration — realistic masking tape */
  .frame-tape {
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%) rotate(1.5deg);
    width: 64px;
    height: 20px;
    background: linear-gradient(
      180deg,
      rgba(245, 240, 232, 0.12),
      rgba(245, 240, 232, 0.06)
    );
    border: 1px solid rgba(245, 240, 232, 0.06);
    pointer-events: none;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  :global(html[data-theme="light"]) .frame-tape {
    background: linear-gradient(
      180deg,
      rgba(200, 190, 170, 0.25),
      rgba(200, 190, 170, 0.12)
    );
    border-color: rgba(200, 190, 170, 0.15);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }

  .photo-frame:nth-child(even) .frame-tape {
    transform: translateX(-40%) rotate(-2deg);
  }

  .photo-frame:nth-child(3n) .frame-tape {
    left: 30%;
    transform: rotate(4deg);
  }

  /* ── Footer ─────────────────────────────────────────────────── */

  .photos-footer {
    padding: 3rem 2.5rem 4rem 3rem;
    border-top: 1px solid var(--photo-border);
    opacity: 0;
    animation: photos-reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .photos-footer-text {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--photo-cream-muted);
    margin: 0;
  }

  .photos-footer-sub {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--photo-cream-muted);
    opacity: 0.5;
    letter-spacing: 0.1em;
    margin-top: 0.5rem;
  }

  /* ── Animations ─────────────────────────────────────────────── */

  @keyframes photos-reveal {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(html[data-astro-navigated]) .photos-header,
  :global(html[data-astro-navigated]) .photos-title-block,
  :global(html[data-astro-navigated]) .photo-frame,
  :global(html[data-astro-navigated]) .photos-footer {
    opacity: 1;
    animation: none;
  }

  /* ── Reduced Motion ──────────────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    .photos-header,
    .photos-title-block,
    .photo-frame,
    .photos-footer {
      animation: none;
      opacity: 1;
    }
    .photo-frame,
    .frame-inner,
    .frame-image {
      transition: none;
    }
    .photo-frame:nth-child(odd),
    .photo-frame:nth-child(even),
    .photo-frame:nth-child(3n) {
      transform: none;
    }
  }

  /* ── Responsive ─────────────────────────────────────────────── */

  @media (max-width: 768px) {
    .photos-gallery {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding-bottom: 4rem;
    }

    .photo-frame:nth-child(odd),
    .photo-frame:nth-child(even),
    .photo-frame:nth-child(3n) {
      transform: rotate(0deg);
    }

    .photos-footer {
      padding: 2rem 1rem 3rem;
    }

    .sprocket-strip {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .photos-gallery {
      grid-template-columns: 1fr;
      max-width: 420px;
    }

    .frame-inner {
      padding: 10px 10px 46px;
    }
  }

  @media (min-width: 1100px) {
    .photo-frame:nth-child(2) {
      margin-top: 3rem;
    }

    .photo-frame:nth-child(3) {
      margin-top: -1rem;
    }

    .photo-frame:nth-child(5) {
      margin-top: 2rem;
    }
  }
</style>
