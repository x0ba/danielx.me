---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../lib/site";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageTitle = "Blog | Daniel Xu";
const pageDescription =
  "Thoughts, notes, and things I've learned about software engineering, product work, and building on the web.";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Daniel Xu Blog",
  description: pageDescription,
  url: Astro.url.toString(),
  inLanguage: "en-US",
  author: {
    "@type": "Person",
    name: siteConfig.author.name,
    url: siteConfig.siteUrl,
  },
  blogPost: posts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    url: new URL(`/blog/${post.id}`, siteConfig.siteUrl).toString(),
    datePublished: post.data.pubDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
    keywords: post.data.tags,
  })),
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={siteConfig.defaultOgImagePath}
  ogImageAlt="Daniel Xu blog preview"
  keywords={[
    "Daniel Xu blog",
    "software engineering blog",
    "web development notes",
  ]}
  structuredData={structuredData}
>
  <div class="top-bar" aria-hidden="true"></div>

  <!-- Hero -->
  <section class="blog-hero">
    <PageHeader currentPath="/blog" />

    <div class="hero-center">
      <h1 class="hero-name">
        <span class="hero-line hero-line-1">the</span>
        <span class="hero-line hero-line-2">blog</span>
      </h1>
      <div class="hero-info">
        <p class="hero-role">thoughts, notes, and things i've learned</p>
        <p class="hero-loc">
          {posts.length}
          {posts.length === 1 ? "post" : "posts"} published
        </p>
      </div>
    </div>
  </section>

  <!-- Content -->
  <div class="content">
    <!-- Posts Section -->
    <section id="posts" class="sec">
      <h2 class="sec-label">Posts</h2>

      {
        posts.length === 0 && (
          <p
            class="blog-empty"
            style="animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.25s both"
          >
            no posts yet. check back soon.
          </p>
        )
      }

      <div class="post-list">
        {
          posts.map((post, i) => (
            <a
              href={`/blog/${post.id}`}
              class="post-item"
              style={`animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) ${0.2 + i * 0.06}s both`}
            >
              <div class="post-item-header">
                <span class="post-item-idx">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <h3 class="post-item-title">{post.data.title}</h3>
                <span class="post-item-rule" />
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="post-item-date"
                >
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
              </div>
              <div class="post-item-body">
                <div class="post-item-body-inner">
                  <p class="post-item-desc">{post.data.description}</p>
                  {post.data.tags.length > 0 && (
                    <div class="post-item-tags">
                      {post.data.tags.map((tag) => (
                        <span class="post-tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <footer class="foot">
      <p>© 2026 Daniel Xu</p>
    </footer>
  </div>
</BaseLayout>

<style>
  /* ── Top Bar ───────────────────── */
  .top-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(
      180deg,
      var(--color-accent-hover),
      var(--color-accent),
      color-mix(in srgb, var(--color-accent) 70%, var(--color-void))
    );
    z-index: 100;
    box-shadow:
      0 1px 4px rgba(255, 61, 0, 0.3),
      0 0 12px rgba(255, 61, 0, 0.15);
  }

  /* ── Hero ───────────────────────── */
  .blog-hero {
    display: grid;
    gap: clamp(1.8rem, 4.5vw, 4rem);
    padding: clamp(1.5rem, 3vw, 3rem) clamp(1rem, 4vw, 3rem)
      clamp(2.75rem, 6vw, 4.75rem);
    position: relative;
    overflow: hidden;
  }

  .hero-center {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(15rem, 22rem);
    align-items: end;
    gap: clamp(1.25rem, 4vw, 4rem);
    padding-top: clamp(0.25rem, 2.5vw, 1.75rem);
  }

  .hero-name {
    margin: 0;
    line-height: 0.85;
    animation: fadeSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }
  .hero-line {
    display: block;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(4rem, 13vw, 10rem);
    letter-spacing: -0.03em;
    color: var(--color-primary);
  }
  .hero-line-2 {
    margin-left: clamp(1.25rem, 8vw, 6.5rem);
    color: var(--color-accent);
  }

  .hero-info {
    margin: 0 0 0.45rem;
    padding: 0.9rem 0 0.1rem;
    border-top: 1px solid var(--color-edge);
    animation: fadeSlideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
  }
  .hero-role {
    font-size: clamp(0.9rem, 0.86rem + 0.22vw, 1rem);
    color: var(--color-secondary);
    margin: 0;
    line-height: 1.65;
    text-wrap: pretty;
  }
  .hero-loc {
    font-size: 0.75rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0.45rem 0 0;
  }


  /* ── Content ───────────────────── */
  .content {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem);
  }

  /* ── Sections ──────────────────── */
  .sec {
    padding: clamp(4rem, 7vw, 5.75rem) 0 4rem;
    border-top: 1px solid var(--color-edge);
  }
  .sec-label {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 400;
    color: var(--color-primary);
    margin: 0 0 clamp(2rem, 4vw, 2.75rem);
    letter-spacing: -0.02em;
    text-shadow:
      0 1px 0 rgba(255, 255, 255, 0.03),
      0 -1px 0 rgba(0, 0, 0, 0.4);
  }

  /* ── Blog Empty ─────────────────── */
  .blog-empty {
    font-size: 0.875rem;
    color: var(--color-muted);
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-edge);
    text-wrap: pretty;
  }

  /* ── Post List (matches homepage project cards) ─── */
  .post-list {
    display: grid;
    gap: 0;
    border-top: 1px solid color-mix(in srgb, var(--color-edge) 72%, transparent);
  }

  .post-item {
    display: block;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--color-edge);
    border-radius: 2px;
    padding: 1.3rem 0.85rem;
    margin: 0 -0.85rem;
    transition:
      background 0.28s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.28s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.28s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    outline: none;
  }
  .post-item:hover,
  .post-item:focus-visible {
    background: var(--color-accent-dim);
    border-bottom-color: color-mix(
      in srgb,
      var(--color-accent) 24%,
      var(--color-edge)
    );
    box-shadow:
      0 1px 0 color-mix(in srgb, var(--color-edge-hover) 65%, transparent),
      0 6px 18px rgba(0, 0, 0, 0.13),
      inset 0 1px 0 rgba(255, 255, 255, 0.035);
    transform: translateY(-1px);
  }
  .post-item:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .post-item-header {
    display: flex;
    align-items: baseline;
    gap: clamp(0.75rem, 2vw, 1rem);
    min-width: 0;
  }
  .post-item-idx {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-accent);
    min-width: 2.5rem;
    opacity: 0.6;
    line-height: 1;
    transition:
      opacity 0.2s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .post-item-title {
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 1.12rem + 0.65vw, 1.72rem);
    font-weight: 400;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.12;
    letter-spacing: -0.02em;
    transition: color 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }
  .post-item:hover .post-item-idx,
  .post-item:focus-visible .post-item-idx {
    opacity: 0.95;
    transform: translateY(-1px);
  }
  .post-item:hover .post-item-title,
  .post-item:focus-visible .post-item-title {
    color: var(--color-accent);
  }

  .post-item-rule {
    flex: 1;
    height: 1px;
    background: var(--color-edge);
    min-width: 2rem;
  }
  .post-item-date {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-muted);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    flex-shrink: 0;
    transition: color 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .post-item:hover .post-item-date,
  .post-item:focus-visible .post-item-date {
    color: var(--color-secondary);
  }

  .post-item-body {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    opacity: 0;
    padding-left: 3.5rem;
    transition:
      grid-template-rows 0.42s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.32s cubic-bezier(0.16, 1, 0.3, 1),
      padding-top 0.32s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .post-item:hover .post-item-body,
  .post-item:focus-visible .post-item-body {
    grid-template-rows: 1fr;
    opacity: 1;
    padding-top: 0.8rem;
  }
  .post-item-body-inner {
    min-height: 0;
    overflow: hidden;
  }
  .post-item-desc {
    font-size: clamp(0.85rem, 0.82rem + 0.12vw, 0.92rem);
    color: var(--color-secondary);
    line-height: 1.7;
    margin: 0;
    max-width: 62ch;
    text-wrap: pretty;
  }
  .post-item-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.65rem;
    margin-top: 0.75rem;
    padding-bottom: 0.12rem;
  }
  .post-tag {
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    padding: 0.2rem 0.65rem;
    background: var(--color-accent-dim);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 1px 2px rgba(0, 0, 0, 0.15);
    position: relative;
  }
  .post-tag::before,
  .post-tag::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-accent) 30%, transparent);
    transform: translateY(-50%);
  }
  .post-tag::before {
    left: -6px;
  }
  .post-tag::after {
    right: -6px;
  }
  .post-tag:first-child::before,
  .post-tag:last-child::after {
    display: none;
  }

  /* ── Reduced Motion ────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero-name,
    .hero-info,
    .blog-empty,
    .post-item {
      animation: none !important;
    }
    .post-item,
    .post-item-idx,
    .post-item-title,
    .post-item-date,
    .post-item-body {
      transition: none;
    }
    .post-item:hover,
    .post-item:focus-visible {
      transform: none;
    }
  }

  /* ── Footer ────────────────────── */
  .foot {
    padding: 3rem 0 4rem;
    border-top: 1px solid var(--color-edge);
    font-size: 0.65rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  /* ── Mobile ────────────────────── */
  @media (max-width: 768px) {
    .blog-hero {
      gap: 2rem;
      padding-bottom: 3rem;
    }
    .hero-center {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 1.25rem;
      padding-top: 0.75rem;
    }
    .hero-line {
      font-size: clamp(3.25rem, 20vw, 8rem);
    }
    .hero-line-2 {
      margin-left: min(6vw, 1.5rem);
    }
    .hero-info {
      max-width: 22rem;
      margin: 0;
    }
    .sec {
      padding: 3rem 0 2.5rem;
    }
    .sec-label {
      font-size: 2rem;
    }
    .post-item {
      padding: 1.35rem 0;
      margin: 0;
    }
    .post-item-header {
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 0.5rem 0.75rem;
    }
    .post-item-rule {
      display: none;
    }
    .post-item-body {
      display: block;
      grid-template-rows: none;
      overflow: visible;
      opacity: 1;
      padding-left: 0;
      padding-top: 0.7rem;
    }
    .post-item-idx {
      display: none;
    }
    .post-item-title {
      flex-basis: 100%;
      white-space: normal;
      overflow-wrap: anywhere;
    }
    .post-item:hover,
    .post-item:focus-visible {
      transform: none;
    }
  }
</style>
