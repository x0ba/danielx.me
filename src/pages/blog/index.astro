---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ThemeSwitcher from "../../components/ThemeSwitcher.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../lib/site";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageTitle = "Blog | Daniel Xu";
const pageDescription =
  "Thoughts, notes, and things I've learned about software engineering, product work, and building on the web.";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Daniel Xu Blog",
  description: pageDescription,
  url: Astro.url.toString(),
  inLanguage: "en-US",
  author: {
    "@type": "Person",
    name: siteConfig.author.name,
    url: siteConfig.siteUrl,
  },
  blogPost: posts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    url: new URL(`/blog/${post.id}`, siteConfig.siteUrl).toString(),
    datePublished: post.data.pubDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
    keywords: post.data.tags,
  })),
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={siteConfig.defaultOgImagePath}
  ogImageAlt="Daniel Xu blog preview"
  keywords={[
    "Daniel Xu blog",
    "software engineering blog",
    "web development notes",
  ]}
  structuredData={structuredData}
>
  <div class="top-bar" aria-hidden="true"></div>

  <div class="blog-wrapper">
    <nav class="blog-nav" style="animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) both">
      <a href="/" class="nav-logo">DX<span class="nav-dot"></span></a>
      <div class="nav-links">
        <a href="/" class="nav-link">home</a>
        <a href="/blog" class="nav-link nav-link--active">blog</a>
        <ThemeSwitcher />
      </div>
    </nav>

    <section class="blog-header">
      <h1 class="blog-heading" style="animation: fadeSlideUp 0.8s cubic-bezier(0.16,1,0.3,1) 0.1s both">blog</h1>
      <p class="blog-sub" style="animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.2s both">
        thoughts, notes, and things i've learned
      </p>
    </section>

    <!-- Posts -->
    <section class="blog-posts">
      {posts.length === 0 && (
        <p class="blog-empty" style="animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.25s both">
          no posts yet. check back soon.
        </p>
      )}

      {posts.map((post, i) => (
        <a
          href={`/blog/${post.id}`}
          class="post-row"
          style={`animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) ${0.25 + i * 0.05}s both`}
        >
          <div class="post-row-main">
            <h2 class="post-row-title">{post.data.title}</h2>
            <p class="post-row-desc">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="post-row-tags">
                {post.data.tags.map((tag) => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
          <time datetime={post.data.pubDate.toISOString()} class="post-row-date">
            {post.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })}
          </time>
        </a>
      ))}
    </section>

    <!-- Footer -->
    <footer class="blog-footer" style={`animation: fadeSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) ${0.3 + posts.length * 0.05}s both`}>
      <p>© 2026 Daniel Xu</p>
    </footer>
  </div>
</BaseLayout>

<style>
  .top-bar {
    position: fixed; top: 0; left: 0; right: 0;
    height: 3px; background: var(--color-accent); z-index: 100;
  }
  .site-grid-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);
    background-size: 80px 80px;
  }

  .blog-wrapper {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  .blog-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2.5rem 0 2rem;
  }

  .nav-logo {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: -0.03em;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }
  .nav-logo:hover { color: var(--color-accent); }

  .nav-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
    margin-left: 2px;
    margin-bottom: -2px;
  }

  .nav-links { display: flex; gap: 2rem; }

  .nav-link {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    transition: color 0.2s;
  }
  .nav-link:hover, .nav-link--active { color: var(--color-primary); }

  .blog-header {
    padding: 5rem 0 3rem;
    border-bottom: 1px solid var(--color-edge);
  }

  .blog-heading {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(3.5rem, 12vw, 6rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 0.9;
    margin: 0;
  }

  .blog-sub {
    font-size: 0.95rem;
    color: var(--color-secondary);
    margin-top: 1rem;
  }

  .blog-posts {
    padding: 1rem 0;
  }

  .blog-empty {
    font-size: 0.875rem;
    color: var(--color-muted);
    padding: 2rem 0;
  }

  .post-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 1.75rem 1rem;
    margin: 0 -1rem;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--color-edge);
    transition: background 0.2s;
    position: relative;
  }
  .post-row::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0;
    background: var(--color-accent);
    transition: width 0.3s cubic-bezier(0.77, 0, 0.175, 1);
  }
  .post-row:hover {
    background: var(--color-accent-dim);
  }
  .post-row:hover::before {
    width: 3px;
  }

  .post-row-main { min-width: 0; flex: 1; }

  .post-row-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--color-primary);
    margin: 0;
    transition: color 0.2s;
  }
  .post-row:hover .post-row-title { color: var(--color-accent); }

  .post-row-desc {
    font-size: 0.85rem;
    color: var(--color-secondary);
    line-height: 1.6;
    margin-top: 0.35rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-row-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .post-tag {
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--color-accent-dim);
    background: var(--color-accent-dim);
  }

  .post-row-date {
    font-size: 0.7rem;
    color: var(--color-muted);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding-top: 0.15rem;
    flex-shrink: 0;
  }

  .blog-footer {
    padding: 3rem 0 4rem;
    font-size: 0.7rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 640px) {
    .blog-wrapper { padding: 0 1.25rem; }
    .blog-header { padding: 3rem 0 2rem; }
    .post-row { flex-direction: column; gap: 0.5rem; }
  }
</style>
