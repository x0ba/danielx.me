---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../lib/site";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageTitle = "Blog | Daniel Xu";
const pageDescription =
  "Thoughts, notes, and things I've learned about software engineering, product work, and building on the web.";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Daniel Xu Blog",
  description: pageDescription,
  url: Astro.url.toString(),
  inLanguage: "en-US",
  author: {
    "@type": "Person",
    name: siteConfig.author.name,
    url: siteConfig.siteUrl,
  },
  blogPost: posts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    url: new URL(`/blog/${post.id}`, siteConfig.siteUrl).toString(),
    datePublished: post.data.pubDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
    keywords: post.data.tags,
  })),
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={siteConfig.defaultOgImagePath}
  ogImageAlt="Daniel Xu blog preview"
  keywords={[
    "Daniel Xu blog",
    "software engineering blog",
    "web development notes",
  ]}
  structuredData={structuredData}
>
  <div class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute left-1/2 top-0 h-[600px] w-[900px] -translate-x-1/2"
      style="background: radial-gradient(ellipse at 50% 0%, rgba(198, 122, 74, 0.045), transparent 70%);"
    >
    </div>

    <div class="relative mx-auto max-w-2xl px-6">
      <!-- Nav -->
      <nav
        class="flex items-center justify-between py-8 opacity-0 animate-reveal"
      >
        <a
          href="/"
          class="text-sm font-medium tracking-tight transition-colors hover:text-accent"
        >
          daniel xu
        </a>
        <div class="flex gap-5 text-sm">
          <a
            href="/"
            class="link-hover text-muted transition-colors hover:text-primary"
          >
            home
          </a>
          <a href="/blog" class="link-hover text-primary transition-colors">
            blog
          </a>
        </div>
      </nav>

      <!-- Header -->
      <section class="pb-16 pt-16 sm:pt-20">
        <h1
          class="text-5xl font-bold tracking-tight opacity-0 animate-reveal sm:text-6xl"
          style="animation-delay: 0.06s"
        >
          blog
        </h1>
        <p
          class="mt-3 text-lg text-secondary opacity-0 animate-reveal"
          style="animation-delay: 0.12s"
        >
          thoughts, notes, and things i've learned
        </p>
      </section>

      <!-- Posts List -->
      <section class="pb-24">
        {
          posts.length === 0 && (
            <p
              class="text-sm text-muted opacity-0 animate-reveal"
              style="animation-delay: 0.18s"
            >
              no posts yet. check back soon.
            </p>
          )
        }

        <div class="grid gap-3">
          {
            posts.map((post, i) => (
              <a
                href={`/blog/${post.id}`}
                class="group rounded-xl border border-edge bg-surface/50 p-5 opacity-0 animate-reveal transition-all duration-300 hover:-translate-y-0.5 hover:border-edge-hover hover:bg-elevated/50 hover:shadow-[0_8px_30px_rgba(198,122,74,0.04)]"
                style={`animation-delay: ${0.18 + i * 0.04}s`}
              >
                <div class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-6">
                  <div class="min-w-0 flex-1">
                    <h2 class="text-base font-medium transition-colors group-hover:text-accent">
                      {post.data.title}
                    </h2>
                    <p class="mt-1.5 text-sm leading-relaxed text-secondary line-clamp-2">
                      {post.data.description}
                    </p>
                    {post.data.tags.length > 0 && (
                      <div class="mt-3 flex flex-wrap gap-1.5">
                        {post.data.tags.map((tag) => (
                          <span class="rounded-full bg-accent-dim px-2.5 py-0.5 text-xs text-accent">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                  <time
                    datetime={post.data.pubDate.toISOString()}
                    class="mt-2 shrink-0 text-xs text-muted sm:mt-0.5"
                  >
                    {post.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </time>
                </div>
              </a>
            ))
          }
        </div>
      </section>

      <!-- Footer -->
      <footer
        class="border-t border-edge pb-12 pt-8 opacity-0 animate-reveal"
        style={`animation-delay: ${0.22 + posts.length * 0.04}s`}
      >
        <p class="text-xs text-muted">
          © 2026 Daniel Xu. built with ❤️ in la jolla, ca
        </p>
      </footer>
    </div>
  </div>
</BaseLayout>
