---
/**
 * PageHeader — A machined instrument-panel navbar.
 *
 * Physical metaphor: the control strip on a darkroom enlarger or
 * the nameplate riveted to a precision tool. Brushed surface,
 * engraved labels, screw fasteners, and a stamped maker's mark.
 */
import ThemeSwitcher from "./ThemeSwitcher.astro";

interface Props {
  /** Current page path for active-link highlighting */
  currentPath?: string;
  /** Set true on pages that use their own color context (e.g. photos) */
  usePageColors?: boolean;
}

const { currentPath = "/", usePageColors = false } = Astro.props;

const links = [
  { href: "/", label: "home" },
  { href: "/photos", label: "photos" },
  { href: "/blog", label: "blog" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<header class:list={["page-header", { "page-header--page-colors": usePageColors }]}>
  <!-- Decorative screw fasteners -->
  <div class="header-screw header-screw--left" aria-hidden="true"></div>
  <div class="header-screw header-screw--right" aria-hidden="true"></div>

  <nav class="header-nav" aria-label="Primary navigation">
    <a href="/" class="header-logo">
      <span class="logo-mark">DX</span><span class="logo-dot"></span>
    </a>

    <div class="header-links">
      {links
        .filter((l) => !(currentPath === "/" && l.href === "/"))
        .map((l) => (
          <a
            href={l.href}
            class:list={["header-link", { "header-link--active": isActive(l.href) }]}
            {...(isActive(l.href) ? { "aria-current": "page" } : {})}
          >
            {l.label}
          </a>
        ))}
      <div class="header-divider" aria-hidden="true"></div>
      <ThemeSwitcher />
    </div>
  </nav>
</header>

<style>
  /* ── Machined Header Strip ─────────────────────────────────── */

  .page-header {
    position: relative;
    z-index: 50;
    padding: clamp(0.65rem, 1.5vw, 0.85rem) clamp(1rem, 4vw, 3rem);
    animation: headerReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes headerReveal {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .header-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;

    /* The machined strip surface */
    padding: 0.6rem 1.25rem;
    border-radius: 3px;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-elevated) 90%, white) 0%,
        var(--color-elevated) 40%,
        color-mix(in srgb, var(--color-elevated) 92%, black) 100%
      );
    border: 1px solid var(--color-edge);
    border-top-color: var(--color-edge-hover);
    border-bottom-color: color-mix(in srgb, var(--color-edge) 70%, black);

    /* Machined surface depth */
    box-shadow:
      /* Outer bevel highlight */
      0 -1px 0 color-mix(in srgb, var(--color-elevated) 60%, white),
      /* Cast shadow underneath */
      0 2px 6px rgba(0, 0, 0, 0.35),
      0 4px 16px rgba(0, 0, 0, 0.15),
      /* Inner highlight along top edge */
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      /* Inner shadow at bottom for depth */
      inset 0 -1px 0 rgba(0, 0, 0, 0.15);
  }

  /* ── Light mode surface ─────────────────────────────── */

  :global(html[data-theme="light"]) .header-nav {
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-elevated) 85%, white) 0%,
        var(--color-elevated) 40%,
        color-mix(in srgb, var(--color-elevated) 95%, black) 100%
      );
    border-color: var(--color-edge);
    border-top-color: color-mix(in srgb, var(--color-edge) 60%, white);
    border-bottom-color: var(--color-edge-hover);
    box-shadow:
      0 -1px 0 rgba(255, 255, 255, 0.5),
      0 2px 6px rgba(0, 0, 0, 0.08),
      0 4px 16px rgba(0, 0, 0, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.6),
      inset 0 -1px 0 rgba(0, 0, 0, 0.04);
  }

  /* ── Page-color variant (photos page etc) ───────────── */

  .page-header--page-colors .header-nav {
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--photo-card, var(--color-elevated)) 90%, white) 0%,
        var(--photo-card, var(--color-elevated)) 40%,
        color-mix(in srgb, var(--photo-card, var(--color-elevated)) 92%, black) 100%
      );
    border-color: var(--photo-border, var(--color-edge));
    border-top-color: var(--photo-border-light, var(--color-edge-hover));
    border-bottom-color: color-mix(in srgb, var(--photo-border, var(--color-edge)) 70%, black);
  }

  :global(html[data-theme="light"]) .page-header--page-colors .header-nav {
    border-top-color: color-mix(in srgb, var(--photo-border, var(--color-edge)) 60%, white);
    border-bottom-color: var(--photo-border-light, var(--color-edge-hover));
  }

  /* ── Screw Fasteners ────────────────────────────────── */

  .header-screw {
    position: absolute;
    top: 50%;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    transform: translateY(-50%);
    background:
      radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.12), transparent 60%),
      conic-gradient(
        from 45deg,
        var(--color-edge-hover) 0deg,
        var(--color-edge) 90deg,
        var(--color-edge-hover) 180deg,
        var(--color-edge) 270deg,
        var(--color-edge-hover) 360deg
      );
    border: 1px solid color-mix(in srgb, var(--color-edge) 80%, black);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 1px 2px rgba(0, 0, 0, 0.3);
  }

  .header-screw::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 5px;
    height: 1px;
    background: rgba(0, 0, 0, 0.4);
    transform: translate(-50%, -50%) rotate(35deg);
    border-radius: 0.5px;
  }

  :global(html[data-theme="light"]) .header-screw {
    background:
      radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.5), transparent 60%),
      conic-gradient(
        from 45deg,
        var(--color-edge) 0deg,
        var(--color-edge-hover) 90deg,
        var(--color-edge) 180deg,
        var(--color-edge-hover) 270deg,
        var(--color-edge) 360deg
      );
    border-color: var(--color-edge-hover);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      0 1px 2px rgba(0, 0, 0, 0.08);
  }

  :global(html[data-theme="light"]) .header-screw::after {
    background: rgba(0, 0, 0, 0.15);
  }

  .header-screw--left {
    left: clamp(1.35rem, 4vw, 3.35rem);
  }

  .header-screw--right {
    right: clamp(1.35rem, 4vw, 3.35rem);
  }

  /* ── Logo Mark — Stamped manufacturer plate ─────────── */

  .header-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    gap: 0;
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
    transition:
      background 0.2s,
      box-shadow 0.2s;
  }

  .header-logo:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  :global(html[data-theme="light"]) .header-logo:hover {
    background: rgba(0, 0, 0, 0.03);
  }

  .header-logo:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  .logo-mark {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    text-transform: uppercase;
    /* Debossed / stamped effect */
    text-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06),
      0 -1px 0 rgba(0, 0, 0, 0.4);
    transition: color 0.2s;
  }

  :global(html[data-theme="light"]) .logo-mark {
    text-shadow:
      0 1px 0 rgba(255, 255, 255, 0.5),
      0 -1px 0 rgba(0, 0, 0, 0.08);
  }

  .header-logo:hover .logo-mark {
    color: var(--color-accent);
  }

  .logo-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    background: var(--color-accent);
    border-radius: 50%;
    margin-left: 2px;
    margin-bottom: -1px;
    box-shadow:
      0 0 4px rgba(255, 61, 0, 0.4),
      inset 0 -1px 0 rgba(0, 0, 0, 0.3);
    transition: box-shadow 0.2s;
  }

  .header-logo:hover .logo-dot {
    box-shadow:
      0 0 8px rgba(255, 61, 0, 0.6),
      0 0 16px rgba(255, 61, 0, 0.2),
      inset 0 -1px 0 rgba(0, 0, 0, 0.3);
  }

  :global(html[data-theme="light"]) .logo-dot {
    box-shadow:
      0 0 4px rgba(196, 75, 0, 0.3),
      inset 0 -1px 0 rgba(0, 0, 0, 0.15);
  }

  :global(html[data-theme="light"]) .header-logo:hover .logo-dot {
    box-shadow:
      0 0 8px rgba(196, 75, 0, 0.5),
      0 0 16px rgba(196, 75, 0, 0.15),
      inset 0 -1px 0 rgba(0, 0, 0, 0.15);
  }

  /* ── Navigation Links — Engraved panel labels ───────── */

  .header-links {
    display: flex;
    gap: clamp(0.5rem, 2vw, 1.25rem);
    align-items: center;
  }

  .header-link {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.3rem 0.55rem;
    border-radius: 2px;
    position: relative;
    transition:
      color 0.2s,
      background 0.2s,
      box-shadow 0.2s;

    /* Engraved text */
    text-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04),
      0 -1px 0 rgba(0, 0, 0, 0.2);
  }

  :global(html[data-theme="light"]) .header-link {
    text-shadow:
      0 1px 0 rgba(255, 255, 255, 0.4),
      0 -1px 0 rgba(0, 0, 0, 0.04);
  }

  .header-link:hover {
    color: var(--color-accent);
    background: rgba(255, 61, 0, 0.06);
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.15);
  }

  :global(html[data-theme="light"]) .header-link:hover {
    background: rgba(196, 75, 0, 0.06);
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  .header-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Active link — illuminated indicator */
  .header-link--active {
    color: var(--color-primary);
    background: rgba(255, 255, 255, 0.04);
    box-shadow:
      inset 0 1px 2px rgba(0, 0, 0, 0.2),
      inset 0 -1px 0 rgba(255, 255, 255, 0.04);
  }

  .header-link--active::after {
    content: "";
    position: absolute;
    bottom: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 14px;
    height: 2px;
    border-radius: 1px;
    background: var(--color-accent);
    box-shadow: 0 0 6px rgba(255, 61, 0, 0.4);
  }

  :global(html[data-theme="light"]) .header-link--active {
    background: rgba(0, 0, 0, 0.03);
    box-shadow:
      inset 0 1px 2px rgba(0, 0, 0, 0.05),
      inset 0 -1px 0 rgba(255, 255, 255, 0.4);
  }

  :global(html[data-theme="light"]) .header-link--active::after {
    box-shadow: 0 0 6px rgba(196, 75, 0, 0.3);
  }

  /* ── Vertical divider before theme dial ──────────────── */

  .header-divider {
    width: 1px;
    height: 18px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      var(--color-edge-hover) 30%,
      var(--color-edge-hover) 70%,
      transparent 100%
    );
    margin: 0 clamp(0.15rem, 0.8vw, 0.35rem);
  }

  :global(html[data-theme="light"]) .header-divider {
    background: linear-gradient(
      180deg,
      transparent 0%,
      var(--color-edge) 30%,
      var(--color-edge) 70%,
      transparent 100%
    );
  }

  /* ── Reduced Motion ─────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    .page-header {
      animation: none;
    }
    .header-logo,
    .header-link,
    .logo-dot {
      transition: none;
    }
  }

  /* ── Responsive ─────────────────────────────────────── */

  @media (max-width: 520px) {
    .header-nav {
      padding: 0.5rem 0.85rem;
    }

    .header-links {
      gap: 0.4rem;
    }

    .header-link {
      font-size: 0.58rem;
      padding: 0.25rem 0.4rem;
      letter-spacing: 0.1em;
    }

    .header-screw {
      width: 6px;
      height: 6px;
    }

    .header-screw::after {
      width: 4px;
    }

    .header-screw--left {
      left: clamp(1.2rem, 4vw, 3.2rem);
    }

    .header-screw--right {
      right: clamp(1.2rem, 4vw, 3.2rem);
    }
  }

  @media (max-width: 380px) {
    .header-divider {
      display: none;
    }

    .header-links {
      flex-wrap: wrap;
      justify-content: flex-end;
    }
  }
</style>
